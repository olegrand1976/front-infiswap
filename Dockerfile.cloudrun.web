# Image runtime-only du front (SSR Nuxt) pour Cloud Run.
# Le build (`npm run build`) est réalisé en amont par le Cloud Build du back
# (infra/gcp/cloudbuild-web-only.yaml) ; ici on ne package que le .output autonome.
FROM node:20.18.0-slim

WORKDIR /app

COPY .output ./.output
COPY package.json ./package.json

RUN if ! getent group www-data >/dev/null 2>&1; then groupadd -r www-data; fi \
    && if ! id -u www-data >/dev/null 2>&1; then useradd -r -g www-data www-data; fi \
    && chown -R www-data:www-data /app

USER www-data

ENV NODE_ENV=production
ENV PORT=8080

EXPOSE 8080

CMD ["node", ".output/server/index.mjs"]
